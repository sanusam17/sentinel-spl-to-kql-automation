{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/1b03ba4f-e8b9-4c90-a108-4bd4263e9d1d')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/1b03ba4f-e8b9-4c90-a108-4bd4263e9d1d')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2022-11-01-preview",
            "properties": {
                "displayName": "Multiple Failed Azure Activity by Caller",
                "description": "Detects when a specific caller has initiated 5 or more failed activities from the same IP address within a defined period. This could indicate brute-force attempts or misconfigurations.",
                "severity": "Medium",
                "enabled": true,
                "query": "AzureActivity\n| where ActivityStatus == \"Failed\"\n| summarize count() by Caller, CallerIpAddress\n| where count_ >= 5",
                "queryFrequency": "PT1H",
                "queryPeriod": "PT24H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT1H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "Initial Access",
                    "Defense Evasion"
                ],
                "techniques": [
                    "T1078 - Valid Accounts",
                    "T1550 - Use Alternate Authentication Material"
                ],
                "alertRuleTemplateName": "6e95aef3-a1e0-4063-8e74-cd59aa59f245",
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "Account"
                        ],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": null,
                "customDetails": null,
                "entityMappings": [
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "source": "Caller",
                                "displayName": "Caller"
                            }
                        ]
                    },
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "source": "CallerIpAddress",
                                "displayName": "Caller IP Address"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": "1.0.2"
            }
        }
    ]
}